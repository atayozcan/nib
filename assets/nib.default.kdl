// nib default config — pure vi-style modal controls, no Ctrl bindings.
//
// Every key here can be overridden in $XDG_CONFIG_HOME/nib/nib.kdl with the
// exact same shape. You don't have to redeclare what you're happy with.

behavior {
    tab_width 4
    line_numbers #false
    chord_timeout_ms 500
}

theme {
    foreground "reset"
    background "reset"
    status_fg "#1e1e2e"
    status_bg "#cdd6f4"
    cmdline_fg "#cdd6f4"
    cmdline_bg "reset"
}

// --- Normal mode ---
keymap "normal" {
    // motions (hjkl)
    h "cursor.left"
    j "cursor.down"
    k "cursor.up"
    l "cursor.right"
    "0" "cursor.line_start"
    "$" "cursor.line_end"
    w "cursor.word_forward"
    b "cursor.word_back"
    G "buffer.goto_end"
    g {
        g "buffer.goto_start"
    }

    // motions (arrow keys / nav cluster — same actions, ergonomic alias)
    "<Left>" "cursor.left"
    "<Down>" "cursor.down"
    "<Up>" "cursor.up"
    "<Right>" "cursor.right"
    "<Home>" "cursor.line_start"
    "<End>" "cursor.line_end"

    // mode transitions
    i "mode.insert"
    a "mode.insert_after"
    I "mode.insert_line_start"
    A "mode.insert_line_end"
    o "mode.open_below"
    ":" "mode.command"

    // edits
    x "edit.delete_forward"
    "<Delete>" "edit.delete_forward"
    d {
        d "edit.delete_line"
    }
    u "edit.undo"
    U "edit.redo"

    // lifecycle (vi shortcut)
    Z {
        Z "editor.save_quit"
    }

    // safety
    "<Esc>" "mode.normal"
}

// --- Insert mode ---
// Most keys in insert mode are NOT bound here — they fall through to the
// text-insertion default. Only the escape hatch and a few useful editing
// keys are wired explicitly. Arrow keys are bound here for ergonomics —
// classic vi makes you Esc out to move, which is hostile for a beginner.
keymap "insert" {
    "<Esc>" "mode.normal"
    "<Enter>" "edit.newline"
    "<Tab>" "edit.indent"
    "<Backspace>" "edit.backspace"
    "<Delete>" "edit.delete_forward"
    "<Left>" "cursor.left"
    "<Down>" "cursor.down"
    "<Up>" "cursor.up"
    "<Right>" "cursor.right"
    "<Home>" "cursor.line_start"
    "<End>" "cursor.line_end"
}

// --- Command-line mode ---
// Printable keys fall through and append to the cmdline buffer; backspace
// pops a character (or cancels if empty). These bindings handle the special
// terminators.
keymap "command" {
    "<Esc>" "mode.normal"
    "<Enter>" "cmdline.execute"
}
